# CodeBridge Backend Environment Variables
# Copy to .env and fill in your values

# Google Gemini API (get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here

# Google Cloud Project (for Vertex AI, Firestore, etc.)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# LiveKit (get from https://cloud.livekit.io)
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# Redis (local dev or Memorystore URL)
REDIS_URL=redis://localhost:6379

# App Config
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
