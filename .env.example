# CodeBridge — copy to .env and fill in
# Backend reads from project root when running: PYTHONPATH=. uvicorn ...

GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=gemini-codebridge

# Vertex AI (GCP billing) — deployed app uses these to avoid free-tier limits
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

REDIS_URL=redis://localhost:6379
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# Agentic mode: route captions through Bridge Agent for enrichment (default: true)
AGENTIC_MODE=true

# Billing alert — email when GCP spend reaches $60 (optional)
# Get billing account: gcloud billing accounts list
# BILLING_ACCOUNT_ID=01ABCD-23EF56-789ABC
# BILLING_ALERT_EMAIL=your-email@example.com
